<div class="card card-bordered">
  <div class="card-body flex flex-row justify-between items-center py-2 px-5">
    <div class="flex gap-1 items-center">
      <%= link_to category.name.humanize, category_path(category), class: "link link-hover font-bold" %>
    </div>
    <div class="flex">
      <%= link_to edit_category_path(category), class: "btn btn-circle btn-ghost btn-sm" do %>
        <i class="fa-regular fa-pen-to-square"></i>
      <% end %>
      <%= button_to category_path(category), method: :delete, class: "btn btn-circle btn-ghost btn-sm" do %>
        <i class="fa-regular fa-trash-can"></i>
      <% end %>
    </div>
  </div>
</div>
